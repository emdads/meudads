# Environment variables for Vercel + Neon deployment

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-example.us-east-1.aws.neon.tech/dbname?sslmode=require"
POSTGRES_URL="postgresql://user:password@ep-example.us-east-1.aws.neon.tech/dbname?sslmode=require"

# Authentication & Security
JWT_SECRET="your-jwt-secret-key-here"
CRYPTO_KEY="c8e2b9f7a1d4e6f8c9e2b7f4a1d6e8f9c2e5b8f1a4d7e9f2c5e8b1f4a7d9e2f5c8"
CRYPTO_IV="a1b2c3d4e5f6a7b8c9d0e1f2"

# Email Service
RESEND_API_KEY="re_your_resend_api_key_here"
FROM_EMAIL="noreply@yourdomain.com"

# Meta/Facebook API
GRAPH_API_VER="v21.0"

# User Service (optional - if using Mocha Users Service)
MOCHA_USERS_SERVICE_API_KEY="your-mocha-users-api-key"
MOCHA_USERS_SERVICE_API_URL="https://users.mocha.app"

# Platform identifier
DATABASE_PLATFORM="neon"
DEPLOYMENT_PLATFORM="vercel"
