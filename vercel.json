{
  "installCommand": "cp package-vercel.json package.json && npm install",
  "buildCommand": "npx vite build --config vite.config.vercel.ts",
  "framework": null,
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "runtime": "@vercel/node@2.15.10"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
