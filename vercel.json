{
  "installCommand": "cp package-vercel.json package.json && npm install",
  "buildCommand": "npx vite build --config vite.config.vercel.ts",
  "framework": null,
  "outputDirectory": "dist",
  "functions": {
    "src/worker/index.ts": {
      "runtime": "edge"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
